# EditorConfig: https://editorconfig.org
# 跨编辑器一致性（VS Code / Cursor / WebStorm / Sublime …）
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2
max_line_length = 100

[*.md]
trim_trailing_whitespace = false
max_line_length = off

[*.py]
indent_size = 4
max_line_length = 100

[*.{html,htm}]
indent_size = 2

[*.svg]
insert_final_newline = true
indent_size = 2

[Makefile]
indent_style = tab
